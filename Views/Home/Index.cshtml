@using System.Security.Claims
@using Hub.Services
@{
    ViewData["Title"] = "Home page";
}
@inject ITenantService TenantService
@{
    var clientId = ViewBag.ClientID;

    bool clientInternal = false;
    if (ViewBag.ClientInternal != null)
    {
        if (ViewBag.ClientInternal is bool)
        {
            clientInternal = (bool)ViewBag.ClientInternal;
        }
        else
        {
            bool.TryParse(ViewBag.ClientInternal.ToString(), out clientInternal);
        }
    }

    // Check if user is a courier
    bool isCourier = false;
    var isCourierClaim = User.FindFirst("IsCourier")?.Value;
    if (!string.IsNullOrEmpty(isCourierClaim))
    {
        bool.TryParse(isCourierClaim, out isCourier);
    }

    // var clientName = ViewBag.ClientName;
    // var clientCreated = ViewBag.ClientCreated;
    //var clientStripe = ViewBag.ClientStripe;

    var contactId = ViewBag.ContactID;
    // var contactName = ViewBag.ContactName;
    // var contactFullName = ViewBag.ContactFullName;
    // var contactEmail = ViewBag.ContactEmail;
    // var contactCreated = ViewBag.ContactCreated;
    var greetingString = ViewBag.GreetingString;
    // var despatchWebPermission = ViewBag.DespatchWebPermission;
    var userEmail = ViewBag.UserEmail;
    var tenantCode = ViewBag.TenantCode;

    // Check if this is the special urgent/asure user that needs custom redirect
    bool isUrgentAsureUser = !string.IsNullOrEmpty(userEmail) &&
                             !string.IsNullOrEmpty(tenantCode) &&
                             userEmail.Equals("asure@urgent.co.nz", StringComparison.OrdinalIgnoreCase) &&
                             tenantCode.Equals("urgent", StringComparison.OrdinalIgnoreCase);

    var bookingAppUrl = Environment.GetEnvironmentVariable("TenantURL").Replace("app_name", "booking");
    var bookingAppPath = isUrgentAsureUser ? "/#/asure" : "/#/login/";
    var bookingAppFullUrl = bookingAppUrl + bookingAppPath;

    bool bookJobPermission = false;
    if (ViewBag.BookJobPermission != null)
    {
        if (ViewBag.BookJobPermission is bool)
        {
            bookJobPermission = (bool)ViewBag.BookJobPermission;
        }
        else
        {
            bool.TryParse(ViewBag.BookJobPermission.ToString(), out bookJobPermission);
        }
    }

    bool bulkUploadPermission = false;
    if (ViewBag.BulkUploadPermission != null)
    {
        if (ViewBag.BulkUploadPermission is bool)
        {
            bulkUploadPermission = (bool)ViewBag.BulkUploadPermission;
        }
        else
        {
            bool.TryParse(ViewBag.BulkUploadPermission.ToString(), out bulkUploadPermission);
        }
    }
}
<script>
var ClientID = '@clientId';
    var ContactID = '@contactId';
    var GreetingString = '@greetingString';
</script>

<div class="text-center">
    <div style="padding-bottom:8px;">
        @await Component.InvokeAsync("TenantLogo", new { cssClass = "logo", alt = "Deliver Different" })
    </div>
    <h4 style="color: #283DB8; ">App Hub</h4>
</div>

<div id="urgent-hub">
    <div class="dash-boxes container-fluid">
        @if (isCourier)
        {
            <!-- Courier users only see CourierPortal and AfterHours -->
            <div class="row">
                <div class="col-sm-4">
                    <div class="dash-box icon" onclick="window.open('@Environment.GetEnvironmentVariable("TenantURL").Replace("app_name", "courierportal")')">
                        <i class="fas fa-hamsa"></i>
                        <div class="text">Courier Portal</div>
                    </div>
                </div>
                @if (ViewBag.ShowAfterHours == true)
                {
                    <div class="col-sm-4">
                        <div class="dash-box icon" onclick="window.open('@Environment.GetEnvironmentVariable("TenantURL").Replace("app_name", "afterhours")')">
                            <i class="fas fa-moon"></i>
                            <div class="text">After Hours</div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (!clientInternal)
        {
            <!-- External-only apps (clientInternal = false) -->
            <div class="row">
                @if (bookJobPermission)
                {
                    <div class="col-sm-4">
                        <div class="dash-box icon" onclick="window.open('@bookingAppFullUrl')">
                            <i class="fas fa-atlas"></i>
                            <div class="text">Booking Page</div>
                        </div>
                    </div>
                }
                @if (bulkUploadPermission)
                {
                    <div class="col-sm-4">
                        <div class="dash-box icon" onclick="window.open('@Environment.GetEnvironmentVariable("TenantURL").Replace("app_name", "bulkimport")' + '/#/login/')">
                            <i class="fas fa-file-import"></i>
                            <div class="text">Bulk Import</div>
                        </div>
                    </div>
                }
                <div class="col-sm-4">
                    <div class="dash-box icon" onclick="window.open('@Environment.GetEnvironmentVariable("TenantURL").Replace("app_name", "tracking")')">
                        <i class="fas fa-route"></i>
                        <div class="text">Tracker</div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <!-- All apps for internal users (clientInternal = true) in original order -->
            <!-- First row -->
            <div class="row">
                <div class="col-sm-4">
                    <div class="dash-box icon" onclick="window.open('@Environment.GetEnvironmentVariable("TenantURL").Replace("app_name", "accounts")')">
                        <i class="fas fa-street-view"></i>
                        <div class="text">Accounts</div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="dash-box icon" onclick="window.open('@Environment.GetEnvironmentVariable("TenantURL").Replace("app_name", "adminmanager")')">
                        <i class="fas fa-cogs"></i>
                        <div class="text">Admin Manager</div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="dash-box icon" onclick="window.open('@bookingAppFullUrl')">
                        <i class="fas fa-atlas"></i>
                        <div class="text">Booking Page</div>
                    </div>
                </div>
            </div>

            <!-- Second row -->
            <div class="row">
                <div class="col-sm-4">
                    <div class="dash-box icon" onclick="window.open('@Environment.GetEnvironmentVariable("TenantURL").Replace("app_name", "bulkimport")' + '/#/login/')">
                        <i class="fas fa-file-import"></i>
                        <div class="text">Bulk Import</div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="dash-box icon" onclick="window.open('@Environment.GetEnvironmentVariable("TenantURL").Replace("app_name", "clientmanager")')">
                        <i class="fas fa-user-plus"></i>
                        <div class="text">Client Manager</div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="dash-box icon" onclick="window.open('@Environment.GetEnvironmentVariable("TenantURL").Replace("app_name", "despatch")')">
                        <i class="fas fa-window-maximize"></i>
                        <div class="text">Dispatch</div>
                    </div>
                </div>
            </div>

            <!-- Third row -->
            <div class="row">
                <div class="col-sm-4">
                    <div class="dash-box icon" onclick="window.open('@Environment.GetEnvironmentVariable("TenantURL").Replace("app_name", "couriermanager")')">
                        <i class="fas fa-dolly"></i>
                        <div class="text">Courier Manager</div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="dash-box icon" onclick="window.open('@Environment.GetEnvironmentVariable("TenantURL").Replace("app_name", "courierportal")')">
                        <i class="fas fa-hamsa"></i>
                        <div class="text">Courier Portal</div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="dash-box icon" onclick="window.open('@Environment.GetEnvironmentVariable("TenantURL").Replace("app_name", "tracking")')">
                        <i class="fas fa-route"></i>
                        <div class="text">Tracker</div>
                    </div>
                </div>
            </div>

            <!-- Fourth row -->
            <div class="row">
                <div class="col-sm-4">
                    <div class="dash-box icon" onclick="window.open('@Environment.GetEnvironmentVariable("TenantURL").Replace("app_name", "runviewer")')">
                        <i class="fas fa-map-marked-alt"></i>
                        <div class="text">Route Viewer</div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="dash-box icon" onclick="window.open('@Environment.GetEnvironmentVariable("TenantURL").Replace("app_name", "runbuilder")')">
                        <i class="fas fa-project-diagram"></i>
                        <div class="text">Route Builder</div>
                    </div>
                </div>
                <div class="col-sm-4">
                    <div class="dash-box icon" onclick="window.open('@Environment.GetEnvironmentVariable("TenantURL").Replace("app_name", "runviewer")' + '/#/print')">
                        <i class="fas fa-print"></i>
                        <div class="text">Print</div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>