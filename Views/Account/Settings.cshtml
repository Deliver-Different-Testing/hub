@using UrgentHub.ViewModels
@model List<TenantUserSettingViewModel>


<h2>User Settings</h2>

<form method="post">
    <div class="card mb-4">
        <div class="card-header">
            <h3>API Key</h3>
        </div>
        <div class="card-body">
            <div class="form-group">
                <label for="ApiKey">API Key</label>
                <input type="text" class="form-control" id="ApiKey" name="ApiKey" value="@Model.FirstOrDefault(x=>x.Name == "APIKey")?.Value" />
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <h3>Other Settings</h3>
        </div>
        <div class="card-body">
            <table class="table">
                <thead>
                <tr>
                    <th>Setting</th>
                    <th>Value</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var setting in Model.Where(x=>x.Name != "APIKey"))
                {
                    <tr>
                        <td>@setting.Name</td>
                        <td>
                            <input type="text" class="form-control" name="OtherSettings[@setting.Name]" value="@setting.Value" />
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Save Settings</button>
</form>